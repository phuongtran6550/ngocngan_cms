upstream ngocngan_api {
  server 127.0.0.1:4000;
  keepalive 64;
}

server {
  listen 80;
  listen [::]:80;
  server_name cms.tiembacngocchau.vn;

  root /home/https/www/cms/dist;
  index index.html;

  access_log /home/https/logs/cms/access.log;
  error_log /home/https/logs/cms/error.log warn;

  client_max_body_size 30m;
  client_body_buffer_size 256k;
  client_body_timeout 120s;
  keepalive_timeout 65s;
  send_timeout 120s;

  gzip on;
  gzip_comp_level 5;
  gzip_min_length 1024;
  gzip_types
    text/plain
    text/css
    text/javascript
    application/javascript
    application/json
    application/xml
    image/svg+xml;

  location /api/ {
    access_log /home/https/logs/api/nginx-access.log;
    error_log /home/https/logs/api/nginx-error.log warn;

    proxy_pass http://ngocngan_api;
    proxy_http_version 1.1;

    proxy_request_buffering off;
    proxy_buffering off;
    proxy_max_temp_file_size 0;

    proxy_connect_timeout 10s;
    proxy_send_timeout 180s;
    proxy_read_timeout 180s;

    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location ^~ /uploads/ {
    access_log /home/https/logs/api/nginx-access.log;
    error_log /home/https/logs/api/nginx-error.log warn;

    proxy_pass http://ngocngan_api;
    proxy_http_version 1.1;

    proxy_buffering on;
    proxy_cache_valid 200 10m;
    expires 7d;
    add_header Cache-Control "public, max-age=604800";

    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location ~* \.(?:js|css|png|jpg|jpeg|gif|svg|ico|webp|woff2?)$ {
    try_files $uri =404;
    expires 30d;
    add_header Cache-Control "public, max-age=2592000, immutable";
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}
